APP_NAME="Sastrería Medina"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com

# stderr (no un archivo dentro del container) para que Coolify vea los logs.
LOG_CHANNEL=stderr
LOG_LEVEL=error

# Coolify da una URL unica de conexion (mysql://usuario:password@host:puerto/db).
# DB_URL pisa host/puerto/db/usuario/password - no hace falta nada mas.
DB_CONNECTION=mysql
DB_URL=

# Impresora termica ESC/POS en red. Con PRINTER_TEST_MODE=true, los tickets se
# escriben en storage/app/tickets/*.txt en vez de imprimirse (util hasta tener
# la IP real de la impresora). PRINTER_PORT=9100 es el puerto raw/JetDirect
# estandar de la mayoria de las impresoras termicas con Ethernet/WiFi.
PRINTER_TEST_MODE=true
PRINTER_HOST=
PRINTER_PORT=9100

# El entrypoint corre "php artisan migrate --force" al arrancar si esto es
# "true". Ponelo en "false" si preferis migrar a mano.
RUN_MIGRATIONS=true
