APP_NAME="Sastrería Medina"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Coolify: apuntar a la base de datos MySQL administrada por Coolify (host = nombre
# del servicio interno, ej. "mysql" o el que Coolify le asigne).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medina
DB_USERNAME=medina
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Impresora termica ESC/POS en red. Con PRINTER_TEST_MODE=true, los tickets se
# escriben en storage/app/tickets/*.txt en vez de imprimirse (util hasta tener
# la IP real de la impresora). PRINTER_PORT=9100 es el puerto raw/JetDirect
# estandar de la mayoria de las impresoras termicas con Ethernet/WiFi.
PRINTER_TEST_MODE=true
PRINTER_HOST=
PRINTER_PORT=9100

# El entrypoint del container corre "php artisan migrate --force" al arrancar
# si esto es "true". Ponelo en "false" si preferis migrar a mano.
RUN_MIGRATIONS=true
